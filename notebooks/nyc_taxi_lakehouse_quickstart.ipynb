  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Trip-level visualizations and lakehouse metrics\n",
    "\n",
    "The following cells summarize key metrics from the marts and visualize trip demand and revenue patterns."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Install plotting dependencies if needed\n",
    "%pip install matplotlib seaborn pandas\n",
    "\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from IPython.display import Image, display\n",
    "\n",
    "sns.set_theme(style=\"whitegrid\")\n",
    "%matplotlib inline\n"
    "%pip install matplotlib seaborn\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "sns.set_theme(style=\"whitegrid\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load curated marts for analysis\n",
    "revenue_df = spark.read.format(\"delta\").load(f\"{gold_path}/revenue_by_borough_day_mart\")\n",
    "demand_df = spark.read.format(\"delta\").load(f\"{gold_path}/demand_by_zone_hour_mart\")\n",
    "\n",
    "# Lakehouse summary metrics\n",
    "total_trips = demand_df.agg({\"pickup_trip_count\": \"sum\"}).collect()[0][0]\n",
    "avg_hourly_trips = demand_df.agg({\"pickup_trip_count\": \"avg\"}).collect()[0][0]\n",
    "total_revenue = revenue_df.agg({\"total_amount\": \"sum\"}).collect()[0][0]\n",
    "avg_daily_revenue = revenue_df.agg({\"total_amount\": \"avg\"}).collect()[0][0]\n",
    "\n",
    "metrics_pdf = pd.DataFrame([\n",
    "    {\"Metric\": \"Total Trips Processed\", \"Value\": int(total_trips)},\n",
    "    {\"Metric\": \"Average Trips per Zone-Hour\", \"Value\": round(float(avg_hourly_trips), 2)},\n",
    "    {\"Metric\": \"Total Revenue (USD)\", \"Value\": round(float(total_revenue), 2)},\n",
    "    {\"Metric\": \"Average Borough-Day Revenue (USD)\", \"Value\": round(float(avg_daily_revenue), 2)},\n",
    "] )\n",
    "\n",
    "display(metrics_pdf)\n"
    "print(f\"Total Trips Processed: {int(total_trips):,}\")\n",
    "print(f\"Average Trips per Zone-Hour: {avg_hourly_trips:,.2f}\")\n",
    "print(f\"Total Revenue (USD): ${total_revenue:,.2f}\")\n",
    "print(f\"Average Borough-Day Revenue (USD): ${avg_daily_revenue:,.2f}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Convert to pandas for charting\n",
    "top_zones_pdf = (\n",
    "    demand_df.orderBy(\"pickup_trip_count\", ascending=False)\n",
    "    .limit(10)\n",
    "    .toPandas()\n",
    ")\n",
    "\n",
    "hourly_pdf = (\n",
    "    demand_df.groupBy(\"pickup_hour\")\n",
    "    .sum(\"pickup_trip_count\")\n",
    "    .withColumnRenamed(\"sum(pickup_trip_count)\", \"trip_count\")\n",
    "    .orderBy(\"pickup_hour\")\n",
    "    .toPandas()\n",
    ")\n",
    "\n",
    "borough_pdf = (\n",
    "    revenue_df.groupBy(\"borough\")\n",
    "    .sum(\"total_amount\")\n",
    "    .withColumnRenamed(\"sum(total_amount)\", \"revenue\")\n",
    "    .orderBy(\"revenue\", ascending=False)\n",
    "    .toPandas()\n",
    ")\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(22, 6))\n",
    "\n",
    "sns.barplot(data=top_zones_pdf, x=\"pickup_trip_count\", y=\"pickup_location_id\", ax=axes[0], palette=\"Blues_r\")\n",
    "axes[0].set_title(\"Top 10 Pickup Zones by Trip Volume\")\n",
    "axes[0].set_xlabel(\"Trip Count\")\n",
    "axes[0].set_ylabel(\"Pickup Location ID\")\n",
    "\n",
    "sns.lineplot(data=hourly_pdf, x=\"pickup_hour\", y=\"trip_count\", marker=\"o\", ax=axes[1], color=\"#2ca02c\")\n",
    "axes[1].set_title(\"Trip Volume by Hour of Day\")\n",
    "axes[1].set_xlabel(\"Pickup Hour\")\n",
    "axes[1].set_ylabel(\"Trips\")\n",
    "\n",
    "sns.barplot(data=borough_pdf, x=\"borough\", y=\"revenue\", ax=axes[2], palette=\"viridis\")\n",
    "axes[2].set_title(\"Revenue by Borough\")\n",
    "axes[2].set_xlabel(\"Borough\")\n",
    "axes[2].set_ylabel(\"Revenue (USD)\")\n",
    "axes[2].tick_params(axis=\"x\", rotation=45)\n",
    "\n",
    "plt.tight_layout()\n",
    "plot_path = \"../data/gold/trip_metrics_dashboard.png\"\n",
    "plt.savefig(plot_path, dpi=150, bbox_inches=\"tight\")\n",
    "plt.show()\n",
    "display(Image(filename=plot_path))\n",
    "\n",
    "display(top_zones_pdf)\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "**Note:** Run the notebook top-to-bottom to generate and persist the chart image at `data/gold/trip_metrics_dashboard.png` with rendered outputs in-place."
    "plt.show()\n"
   ]
  },
